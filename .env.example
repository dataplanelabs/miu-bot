# miu-bot environment configuration
# Copy to .env and fill in values

# Backend
MIU_BOT_BACKEND__TYPE=postgres
MIU_BOT_DATABASE__URL=postgresql://miubot:miubot@localhost:5432/miubot

# Temporal (for gateway+worker mode)
MIU_BOT_TEMPORAL__SERVER_URL=localhost:7233
MIU_BOT_TEMPORAL__NAMESPACE=miubot

# LLM Provider (at least one required)
MIU_BOT_PROVIDERS__OPENROUTER__API_KEY=
MIU_BOT_PROVIDERS__ANTHROPIC__API_KEY=
MIU_BOT_PROVIDERS__OPENAI__API_KEY=

# Default model
MIU_BOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-opus-4-5

# Gateway
MIU_BOT_GATEWAY__HOST=0.0.0.0
MIU_BOT_GATEWAY__PORT=18790

# Channel tokens (enable as needed)
MIU_BOT_CHANNELS__TELEGRAM__ENABLED=false
MIU_BOT_CHANNELS__TELEGRAM__TOKEN=

# Web search
MIU_BOT_TOOLS__WEB__SEARCH__API_KEY=
